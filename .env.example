# 复制为 .env 后填入（.env 已 gitignore）
# 或编辑 src/main/resources/application-local.yml + SPRING_PROFILES_ACTIVE=local
# 文档：README.md「向量库与 RAG」

SPRING_PROFILES_ACTIVE=local

# Agent 对话（DeepSeek）
AI_DEEPSEEK_API_KEY=your-deepseek-key
AI_DEEPSEEK_MODEL=deepseek-chat
AGENT_SIMULATION_MODE=false

# 火山方舟 Embedding（RAG 向量，与 DeepSeek 独立）
ARK_API_KEY=your-ark-api-key
AI_EMBEDDING_MODEL=ep-your-embedding-endpoint-id
AI_EMBEDDING_MULTIMODAL=false
AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_EMBEDDING_FALLBACK_LOCAL=false
