# 复制为 .env 后填入（.env 已 gitignore）
# 或使用 application-local.yml + SPRING_PROFILES_ACTIVE=local

AI_DEEPSEEK_API_KEY=your-deepseek-key
SPRING_PROFILES_ACTIVE=local

# 火山方舟 Embedding（与 DeepSeek 独立）
ARK_API_KEY=your-ark-api-key
AI_EMBEDDING_PROVIDER=doubao-ark
AI_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_EMBEDDING_MODEL=ep-your-embedding-endpoint-id

# 豆包 bge-m3（VikingDB，与方舟二选一）
# AI_EMBEDDING_PROVIDER=doubao-bge-m3
# VIKINGDB_EMBEDDING_TOKEN=your-token
